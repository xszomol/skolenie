# -----------------------------------------------------------------------
# Skolenie — Production environment variables
# Copy to .env.production and fill in every value before deploying.
# -----------------------------------------------------------------------

# Public domain for the app (no trailing slash, no https://)
APP_DOMAIN=skolenie.yourdomain.com
# Subdomain for MinIO file storage (browsers download files from here)
MINIO_DOMAIN=files.yourdomain.com

# ---- NextAuth ----
# Generate with: openssl rand -base64 32
AUTH_SECRET=REPLACE_ME
AUTH_URL=https://skolenie.yourdomain.com

# ---- Database ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_ME_STRONG_PASSWORD
POSTGRES_DB=skolenie
DATABASE_URL=postgresql://postgres:REPLACE_ME_STRONG_PASSWORD@postgres:5432/skolenie

# ---- MinIO ----
MINIO_ENDPOINT=files.yourdomain.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=REPLACE_ME_ACCESS_KEY
MINIO_SECRET_KEY=REPLACE_ME_SECRET_KEY
MINIO_BUCKET=skolenie

# ---- SMTP (e.g. Brevo free tier: smtp-relay.brevo.com:587) ----
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=REPLACE_ME_SMTP_KEY
SMTP_FROM=skolenie@yourdomain.com
