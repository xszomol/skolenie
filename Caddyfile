# Skolenie — Caddy reverse proxy
# Caddy auto-obtains and renews TLS certificates via Let's Encrypt.
# Set APP_DOMAIN and MINIO_DOMAIN in .env.production before starting.

{$APP_DOMAIN} {
    reverse_proxy app:3000
}

{$MINIO_DOMAIN} {
    # CORS preflight — respond immediately without hitting MinIO
    @preflight method OPTIONS
    handle @preflight {
        header Access-Control-Allow-Origin  "https://{$APP_DOMAIN}"
        header Access-Control-Allow-Methods "GET, HEAD, PUT, DELETE"
        header Access-Control-Allow-Headers "*"
        header Access-Control-Max-Age       "86400"
        respond 204
    }

    # Inject CORS header on every real response
    header Access-Control-Allow-Origin "https://{$APP_DOMAIN}"

    reverse_proxy minio:9000
}
