generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TRAINER
  PARTICIPANT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  firstName    String
  lastName     String
  passwordHash String
  createdAt    DateTime @default(now())

  roles              UserRole[]
  createdCourses     Course[]            @relation("CourseCreator")
  primaryCourses     Course[]            @relation("PrimaryTrainer")
  trainerCourses     CourseTrainer[]
  participantCourses CourseParticipant[]
  sentInvitations    Invitation[]        @relation("InvitedBy")
  testAttempts       TestAttempt[]
  pageProgress       LessonPageProgress[]
  lessonProgress     LessonProgress[]
  passwordResets          PasswordResetToken[]
  pendingPasswordChanges  PendingPasswordChange[]
}

model PendingPasswordChange {
  id              String    @id @default(cuid())
  token           String    @unique @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  newPasswordHash String
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime  @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model UserRole {
  userId String
  role   Role
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
}

model Invitation {
  id          String    @id @default(cuid())
  email       String
  role        Role
  token       String    @unique @default(cuid())
  courseId    String?
  course      Course?   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id])
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
}

model Course {
  id                String   @id @default(cuid())
  name              String
  description       String
  startDate         DateTime
  endDate           DateTime
  materialsAfterEnd Boolean  @default(false)
  createdById       String
  createdBy         User     @relation("CourseCreator", fields: [createdById], references: [id])
  primaryTrainerId  String
  primaryTrainer    User     @relation("PrimaryTrainer", fields: [primaryTrainerId], references: [id])
  createdAt         DateTime @default(now())

  trainers     CourseTrainer[]
  participants CourseParticipant[]
  lessons      Lesson[]
  invitations  Invitation[]
}

model CourseTrainer {
  courseId String
  userId   String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([courseId, userId])
}

model CourseParticipant {
  courseId    String
  userId      String
  confirmedAt DateTime?
  joinedAt    DateTime  @default(now())
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([courseId, userId])
}

model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  name        String
  mandatory   Boolean  @default(true)
  minPageTime Int      @default(30)
  order       Int
  createdAt   DateTime @default(now())

  pages    LessonPage[]
  test     Test?
  progress LessonProgress[]
}

// content is a JSON array of blocks: { type: "text"|"image"|"video"|"audio", ... }
model LessonPage {
  id       String  @id @default(cuid())
  lessonId String
  lesson   Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  order    Int
  title    String?
  content  Json    @default("[]")

  progress LessonPageProgress[]
}

model Test {
  id             String   @id @default(cuid())
  lessonId       String   @unique
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  introText      String?
  timeLimit      Int?
  minPassPercent Int?
  maxRetries     Int      @default(0)
  randomOrder    Boolean  @default(false)
  createdAt      DateTime @default(now())

  questions Question[]
  attempts  TestAttempt[]
}

model Question {
  id     String @id @default(cuid())
  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)
  text   String
  points Int    @default(1)
  order  Int

  answers   Answer[]
  responses QuestionResponse[]
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
}

model TestAttempt {
  id         String    @id @default(cuid())
  testId     String
  test       Test      @relation(fields: [testId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  score      Int?
  maxScore   Int?
  passed     Boolean?

  responses QuestionResponse[]
}

model QuestionResponse {
  id             String      @id @default(cuid())
  attemptId      String
  attempt        TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId     String
  question       Question    @relation(fields: [questionId], references: [id])
  selectedIds    String[]
}

model LessonPageProgress {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  pageId      String
  page        LessonPage @relation(fields: [pageId], references: [id])
  timeSpent   Int        @default(0)
  completedAt DateTime?

  @@unique([userId, pageId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id])
  completedAt DateTime?

  @@unique([userId, lessonId])
}
